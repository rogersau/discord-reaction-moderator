{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "test/**/*.ts",
    "dist-tests",
    "dist-node",
    "src/admin/**",
    "src/runtime/node-*.ts",
    "src/runtime/sqlite-store.ts"
  ]
}

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist-node",
    "rootDir": ".",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    // skipLibCheck required: avoids type errors in excluded Cloudflare files
    // that reference @cloudflare/workers-types (DurableObject, ExecutionContext).
    "skipLibCheck": true
  },
  // include all src files per spec, but exclude Cloudflare-specific code that
  // references workers-only types unavailable in Node runtime (DurableObject,
  // ExecutionContext, DurableObjectNamespace, etc.).
  // IMPORTANT: Add any new Cloudflare-specific src/ files to the exclude list.
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/index.ts",
    "src/env.ts",
    "src/discord.ts",
    "src/discord-interactions.ts",
    "src/discord-commands.ts",
    "src/blocklist.ts",
    "src/gateway.ts",
    "src/reaction-moderation.ts",
    "src/timed-roles.ts",
    "src/types.ts",
    "src/runtime/cloudflare-runtime.ts",
    "src/durable-objects/**/*.ts"
  ]
}

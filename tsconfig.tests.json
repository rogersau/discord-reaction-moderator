{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "dist-tests",
    "rootDir": ".",
    "types": ["@cloudflare/workers-types", "node"],
    "lib": ["ES2022"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "test/**/*.test.ts"],
  "exclude": ["dist-tests"]
}
